# 수집기 인증키 — 이 파일을 `.env` 로 복사하고 값을 채운다.
#   cp collector/.env.example collector/.env && chmod 600 collector/.env
#
# ⚠️ `.env` 는 .gitignore 로 차단된다. 절대 커밋하지 말 것.
# 수집기는 ① 환경변수 → ② 자기 폴더의 .env → ③ ../../bus-test/.env.local 순으로 찾는다.

# ── 버스 위치정보 (경기 수집) ──────────────────────────────
# 국토교통부 TAGO — https://www.data.go.kr/data/15098533/openapi.do
#   ✅ 운영계정 50만/일 · 서울은 TAGO 에 없다(§4.1) — 경기 31개 시군 2,200 노선
#   ⚠️ data.go.kr 인증키는 계정당 1개이며 API 별 '활용신청'으로 권한이 붙는다.
#      같은 키로 노선정보(15098529)·정류소정보(15098534)도 쓴다.
#   config.json의 busKeys와 동일하게 2개를 등록한다. 서울버스 수집기도 별도
#   SEOUL_BUS_KEY가 없으면 GBIS_BUS_KEY를 사용한다.
GBIS_BUS_KEY=
GBIS_BUS_KEY2=

# ── 지하철 실시간 (정시성 검증) ────────────────────────────
# 서울 열린데이터광장 — https://data.seoul.go.kr/together/mypage/actkeyMain.do
#   ⚠️ data.go.kr 과 **별개 계정**이다. 1,000회/일.
#   realtimeStationArrival/ALL은 신분당선·GTX-A 포함 19개 노선과 경기 구간까지
#   한 번에 제공한다(§3.3.2). config.json의 subwayKeys와 동일하게 5개를 등록한다.
SEOUL_SUBWAY_KEY=
SEOUL_SUBWAY_KEY2=
SEOUL_SUBWAY_KEY3=
SEOUL_SUBWAY_KEY4=
SEOUL_SUBWAY_KEY5=
